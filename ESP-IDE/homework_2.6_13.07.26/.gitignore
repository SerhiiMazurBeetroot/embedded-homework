# ==========================================
# ESP-IDF Build Artifacts
# ==========================================
# Exclude the entire build directory (binaries, object files, logs)
build/

# Project configuration generated by menuconfig
sdkconfig
sdkconfig.old

# If using idf-component-manager, you usually ignore the lockfile 
# unless you specifically want to lock dependency versions across machines.
dependencies.lock

# ==========================================
# Python & Testing Cache (Used by ESP-IDF tools)
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
pytest_embedded_log/

# ==========================================
# IDE / Editor Specific Files
# ==========================================
# VS Code (Ignore workspace settings that shouldn't be shared)
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json

# CLion / JetBrains
.idea/
cmake-build-*/

# Eclipse
.settings/
.project
.cproject
